# ============================================================
# Company Debt Content System — Environment Variables
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
# Never commit .env to Git. This .env.example file is safe to commit.
# ============================================================

# ------------------------------------------------------------
# Google Gemini API (for deep research script)
# Get from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# WordPress — companydebt.co.uk
# REST API uses Application Passwords (not your login password)
# Generate at: WP Admin > Users > Profile > Application Passwords
# ------------------------------------------------------------
WP_SITE_URL=https://companydebt.co.uk
WP_USERNAME=your_wp_username_here
WP_APP_PASSWORD=your_wp_application_password_here

# ------------------------------------------------------------
# WordPress Staging (WP Engine)
# Same setup as production but pointing at staging URL
# ------------------------------------------------------------
WP_STAGING_URL=https://your-staging-url.wpengine.com
WP_STAGING_USERNAME=your_wp_staging_username_here
WP_STAGING_APP_PASSWORD=your_wp_staging_application_password_here

# ------------------------------------------------------------
# Monday.com API (if needed for scripts outside Claude)
# Get from: Monday > Profile > Developers > API
# ------------------------------------------------------------
MONDAY_API_KEY=your_monday_api_key_here

# ------------------------------------------------------------
# WP Engine API (optional — for deployment automation)
# Get from: WP Engine > API Access > Generate Token
# ------------------------------------------------------------
WPENGINE_API_USER=your_wpengine_api_user_here
WPENGINE_API_PASSWORD=your_wpengine_api_password_here
